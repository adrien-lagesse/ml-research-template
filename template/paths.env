# Storage paths. Committed defaults; override per machine in paths.local.env.
# ${VAR:-default} means an already-set value wins, so inline env and overrides work.

# Where the LocalLogger writes runs (relative to the repo root, or absolute).
export LOG_ROOT="${LOG_ROOT:-.logs}"

# MLflow. MLFLOW_TRACKING_URI is the one the client reads on its own to pick the
# store; the default writes runs straight into a local SQLite file, so training
# needs no server. Point it at http://127.0.0.1:5000 to log to `just mlflow`.
# The other two configure that server's own stores.
export MLFLOW_TRACKING_URI="${MLFLOW_TRACKING_URI:-sqlite:///.mlflow.db}"
export MLFLOW_BACKEND_STORE_URI="${MLFLOW_BACKEND_STORE_URI:-sqlite:///.mlflow.db}"
export MLFLOW_ARTIFACTS_DESTINATION="${MLFLOW_ARTIFACTS_DESTINATION:-./.mlartifacts}"
