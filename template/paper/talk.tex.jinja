\section{The question}
% ==========================================================================

\begin{frame}{Where deep learning starts}
  \begin{itemize}
    \item Affine maps with a nonlinearity between, trained by backpropagation.
    \item The first model most people reach for, and the block inside bigger nets.
  \end{itemize}
  \begin{theorem}[universal approximation]
    One hidden layer, made wide enough, approximates any continuous function on
    a compact set.
  \end{theorem}
  \begin{block}{The gap we poke at}
    The theorems say \emph{a} width exists -- not \emph{how} wide, nor whether
    the width that fits is the width that generalizes.
  \end{block}
\end{frame}

